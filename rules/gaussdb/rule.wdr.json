{
  "rule_meta": {
    "schema_version": "1.0",
    "rule_version": "1.0.0",
    "rule_name": "GaussDB WDR 扩展规则模板",
    "db_type": "gaussdb",
    "target_versions": ["505.2.1.SPC1000"],
    "updated_at": "2026-03-16",
    "target": "GaussDB WDR (HTML)"
  },
  "dimensions": [
    {
      "dimension_id": 7,
      "name": "运行性能",
      "checks": [
        {
          "check_id": "7.5",
          "name": "Buffer Hit %",
          "priority": "P2",
          "source_module": "wdr",
          "result_type": "percentage",
          "extract": {
            "json_path": "db.wdr.instance_efficiency.buffer_hit_pct",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "%"
          },
          "thresholds": {
            "warning": {"operator": "<", "value": 95},
            "critical": {"operator": "<", "value": 90}
          },
          "optimization_advice": "Buffer 命中率偏低，建议排查热点对象、I/O 压力与 shared_buffers 配置"
        },
        {
          "check_id": "7.6",
          "name": "Soft Parse %",
          "priority": "P2",
          "source_module": "wdr",
          "result_type": "percentage",
          "extract": {
            "json_path": "db.wdr.instance_efficiency.soft_parse_pct",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "%"
          },
          "thresholds": {
            "warning": {"operator": "<", "value": 95},
            "critical": {"operator": "<", "value": 90}
          },
          "optimization_advice": "soft parse 偏低，建议检查游标复用与 SQL 规范化（绑定变量、SQL 文本一致性）"
        },
        {
          "check_id": "7.7",
          "name": "Non-Parse CPU %",
          "priority": "P2",
          "source_module": "wdr",
          "result_type": "percentage",
          "extract": {
            "json_path": "db.wdr.instance_efficiency.non_parse_cpu_pct",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "%"
          },
          "thresholds": {
            "warning": {"operator": "<", "value": 90},
            "critical": {"operator": "<", "value": 80}
          },
          "optimization_advice": "非解析 CPU 占比偏低，建议关注解析开销、执行计划不稳定与 SQL 复用"
        },
        {
          "check_id": "7.8",
          "name": "WalWrite NoWait %",
          "priority": "P1",
          "source_module": "wdr",
          "result_type": "percentage",
          "extract": {
            "json_path": "db.wdr.instance_efficiency.walwrite_nowait_pct",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "%"
          },
          "thresholds": {
            "warning": {"operator": "<", "value": 95},
            "critical": {"operator": "<", "value": 90}
          },
          "optimization_advice": "WAL 写入无等待占比偏低，建议检查存储延迟、WAL 配置与刷盘压力"
        },
        {
          "check_id": "7.9",
          "name": "Effective CPU %",
          "priority": "P2",
          "source_module": "wdr",
          "result_type": "percentage",
          "extract": {
            "json_path": "db.wdr.instance_efficiency.effective_cpu_pct",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "%"
          },
          "thresholds": {
            "warning": {"operator": ">", "value": 80},
            "critical": {"operator": ">", "value": 90}
          },
          "optimization_advice": "有效 CPU 占比偏高，建议结合 Top SQL 与系统 CPU 指标判断是否 CPU 瓶颈"
        },
        {
          "check_id": "7.10",
          "name": "SQL response time P95 (us)",
          "priority": "P1",
          "source_module": "wdr",
          "result_type": "numeric",
          "extract": {
            "json_path": "db.wdr.load_profile.sql_response_time.p95_us",
            "aggregation": "raw",
            "expected_type": "number",
            "unit": "us"
          },
          "thresholds": {
            "warning": {"operator": ">", "value": 100000},
            "critical": {"operator": ">", "value": 500000}
          },
          "optimization_advice": "SQL 响应时间 P95 偏高，建议结合 Top SQL 与 IO/锁等待进一步定位"
        }
      ]
    }
  ]
}
